{
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "groupName": "all minor and patch updates",
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": ["/./"]
    },
    {
      "groupName": "all major updates",
      "matchUpdateTypes": ["major"],
      "matchPackageNames": ["/./"]
    },
    {
      "matchPackageNames": ["dataclasses-json"],
      "allowedVersions": "<0.6.0"
    },
    {
      "groupName": "eslint packages",
      "matchPackageNames": ["eslint", "@eslint/js"]
    }
  ]
}
